# Local server and public origin
HOST=127.0.0.1
PORT=8000
APP_BIND_ADDRESS=127.0.0.1
APP_ORIGIN=http://127.0.0.1:8000,http://localhost:8000

# Optional PostgreSQL connection for running `npm run serve` outside Compose.
# Use either DATABASE_URL or the PG* variables. PG* avoids URL-encoding passwords.
# DATABASE_URL=postgres://eduground_app:replace-me@127.0.0.1:5432/eduground
# PGHOST=127.0.0.1
# PGPORT=5432
# PGDATABASE=eduground
# PGUSER=eduground_app
# PGPASSWORD=replace-me
# PGPASSWORD_FILE=/run/secrets/eduground-runtime-password

# External PostgreSQL TLS. Verification is enabled whenever TLS is enabled.
DATABASE_SSL=false
# DATABASE_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
# DATABASE_SSL_CA_FILE=/run/secrets/provider-root-ca.pem
# Development only; production rejects this escape hatch.
DATABASE_SSL_ALLOW_INSECURE=false

DATABASE_POOL_SIZE=10
DATABASE_CONNECT_TIMEOUT_MS=3000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_STATEMENT_TIMEOUT_MS=10000
MIGRATION_LOCK_TIMEOUT_MS=30000

# Durable per-user Python file mirror. Use "off" for PostgreSQL-only storage.
SUBMISSIONS_DIR=./submissions

# Authentication and request policy
SESSION_TTL_SECONDS=2592000
RUN_HISTORY_LIMIT=500
ALLOW_BEARER_SESSION_TOKENS=false
TRUST_PROXY_HOPS=0
HSTS_MAX_AGE_SECONDS=31536000

# HTTP resource bounds
SERVER_REQUEST_TIMEOUT_MS=30000
SERVER_HEADERS_TIMEOUT_MS=10000
SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
SERVER_MAX_HEADERS=100
SERVER_MAX_REQUESTS_PER_SOCKET=1000

# Docker Compose. Run `npm run secrets:init` before the first start.
POSTGRES_DB=eduground
POSTGRES_USER=eduground
POSTGRES_PASSWORD_FILE=./secrets/postgres_password
APP_DATABASE_PASSWORD_FILE=./secrets/app_database_password
COMPOSE_PROJECT_NAME=fundamentos-de-programacao-playground
IMAGE_TAG=local
