# Local server
HOST=127.0.0.1
PORT=8000
APP_ORIGIN=http://127.0.0.1:8000,http://localhost:8000

# PostgreSQL cloud-save backend. Leave unset to run the static playground only.
DATABASE_URL=postgres://eduground:change-me@127.0.0.1:5432/eduground
DATABASE_SSL=false
DATABASE_POOL_SIZE=10
DATABASE_CONNECT_TIMEOUT_MS=3000
DATABASE_STATEMENT_TIMEOUT_MS=10000

# Durable per-user Python file mirror. Set to "off" to keep files only in PostgreSQL.
SUBMISSIONS_DIR=./submissions

# Authentication
SESSION_TTL_SECONDS=2592000
TRUST_PROXY=false

# Docker Compose development defaults
POSTGRES_DB=eduground
POSTGRES_USER=eduground
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
